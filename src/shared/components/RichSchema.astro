---
/** https://developers.google.com/search/docs/appearance/structured-data/organization */
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  'url': 'https://gadmin.app',
  'image': 'https://gadmin.app/meta-og.webp',
  'sameAs': [
    'https://www.instagram.com/gadmin.app/',
    'https://www.linkedin.com/company/gadmin-app/',
    'https://github.com/gadminapp/gadmin-website',
  ],
  'logo': 'https://gadmin.app/meta-og.webp',
  'name': 'Gadmin',
  'alternateName': 'Gadmin App',
  'description':
    'Gadmin es una agencia de desarrollo de software y productos digitales que construye el ecosistema necesario para que las PyMEs crezcan. Desarrollamos software a medida y productos propios como Conty (control financiero) y Shop (catálogos digitales).',
}

const FAQs = [
  {
    question: '¿Qué es Gadmin?',
    answer:
      'Gadmin es un ecosistema digital diseñado para potenciar PyMEs mediante software a medida y productos innovadores como Conty y Shop.',
  },
  {
    question: '¿Qué productos ofrece el ecosistema de Gadmin?',
    answer:
      'Ofrecemos Conty para el control financiero simplificado y Shop para convertir chats de WhatsApp en ventas reales mediante catálogos digitales profesionales.',
  },
  {
    question: '¿Gadmin realiza desarrollo de software personalizado?',
    answer:
      'Sí, en Gadmin construimos software a medida adaptado a las necesidades específicas de crecimiento de tu negocio, transformando procesos manuales en soluciones digitales eficientes.',
  },
  {
    question: '¿Cómo ayuda Gadmin Shop a mi negocio?',
    answer:
      'Gadmin Shop permite crear un catálogo digital profesional en menos de 24 horas, facilitando pedidos organizados directamente a tu WhatsApp y eliminando la fricción de los PDFs estáticos.',
  },
]

/** https://developers.google.com/search/docs/appearance/structured-data/faqpage */
const FAQSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': FAQs.map(({ answer, question }) => ({
    '@type': 'Question',
    'name': question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': answer,
    },
  })),
}
---

<script is:inline type='application/ld+json' set:html={JSON.stringify(organizationSchema)} />
<script is:inline type='application/ld+json' set:html={JSON.stringify(FAQSchema)} />
