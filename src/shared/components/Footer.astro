---
import logoBg from '@/assets/img/logo-dark.webp'
import LinkedIn from '@/shared/components/icons/LinkedIn.astro'
import { Image } from 'astro:assets'
import Instagram from './icons/Instagram.astro'
---

<footer>
  <div class='wrapper'>
    <div class='footer-agency-top' data-aos='fade-up'>
      <div class='footer-agency-brand'>
        <Image src={logoBg} width={48} height={48} alt='Logo de Gadmin' />
        <div>
          <p class='footer-agency-name'>Gadmin</p>
          <p class='footer-agency-tagline'>Software a medida que impulsa tu negocio</p>
        </div>
      </div>
      <div class='footer-agency-links'>
        <div class='footer-link-group'>
          <p class='footer-link-group-title'>Navegación</p>
          <a href='#services'>Servicios</a>
          <a href='#products'>Productos</a>
          <a href='#process'>Proceso</a>
          <a href='#contact'>Contacto</a>
        </div>
        <div class='footer-link-group'>
          <p class='footer-link-group-title'>Productos</p>
          <a href='https://gadminconty.com'>Gadmin Conty</a>
          <a href='https://gadmin.shop'>Gadmin Shop</a>
        </div>
        <div class='footer-link-group'>
          <p class='footer-link-group-title'>Síguenos</p>
          <div class='footer-socials'>
            <a
              href='https://www.linkedin.com/company/gadmin-app/'
              target='_blank'
              rel='noopener noreferrer'
              aria-label='LinkedIn'
            >
              <LinkedIn size={20} color='#FFFFFF' />
            </a>
            <a
              href='https://www.instagram.com/gadmin.app/'
              target='_blank'
              rel='noopener noreferrer'
              aria-label='Instagram'
            >
              <Instagram size={20} color='#FFFFFF' />
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class='footer-divider'></div>

    <div class='footer-bottom'>
      <div class='footer-brand'>
        <Image src={logoBg} width={32} height={32} alt='Logo de Gadmin' />
        <div class='footer-brand-text'>
          <strong>Gadmin</strong>
          <span>© 2026 · Todos los derechos reservados</span>
        </div>
      </div>
      <div class='footer-legal-links'>
        <a href='/terms-and-conditions'>Términos y Condiciones</a>
        <a href='/privacy-policy'>Política de Privacidad</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 3rem 1rem 2rem;
    background: linear-gradient(180deg, var(--shade-03) 0%, #0d0b1a 100%);
  }

  /* === Agency Footer === */
  .footer-agency-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    margin-bottom: 2.5rem;
    align-items: start;
  }

  .footer-agency-brand {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .footer-agency-name {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
  }

  .footer-agency-tagline {
    margin: 0.2rem 0 0;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 400;
    line-height: 1.4;
  }

  .footer-agency-links {
    display: flex;
    gap: 3rem;
    justify-content: flex-end;
  }

  .footer-link-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link-group-title {
    margin: 0 0 0.25rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.35);
    font-weight: 600;
  }

  .footer-link-group a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link-group a:hover {
    color: var(--white);
  }

  .footer-link-group a:visited {
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .footer-socials a {
    display: inline-flex;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .footer-socials a:hover {
    opacity: 1;
  }

  /* === Shared === */
  .footer-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);
    margin-bottom: 1.5rem;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .footer-brand-text strong {
    font-size: 0.95rem;
    color: var(--white);
    font-weight: 600;
  }

  .footer-brand-text span {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    font-weight: 400;
  }

  .footer-legal-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-legal-links a {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-legal-links a:hover {
    color: var(--white);
  }

  .footer-legal-links a:visited {
    color: rgba(255, 255, 255, 0.4);
  }

  @media screen and (max-width: 768px) {
    .footer-agency-top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-agency-brand {
      justify-content: center;
      text-align: center;
      flex-direction: column;
      align-items: center;
    }

    .footer-agency-links {
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .footer-link-group {
      align-items: center;
      text-align: center;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }

    .footer-brand {
      flex-direction: column;
    }

    .footer-brand-text {
      align-items: center;
    }

    .footer-legal-links {
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }
  }
</style>
