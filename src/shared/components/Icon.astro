<svg
  xmlns='http://www.w3.org/2000/svg'
  width={size}
  height={size}
  viewBox='0 0 24 24'
  fill={solid ? 'currentColor' : 'none'}
  stroke={solid ? 'none' : 'currentColor'}
  stroke-width={solid ? 0 : strokeWidth}
  class:list={className}
  style={typeof style === 'string' ? `${style}; color: ${color}` : { ...(style || {}), color }}
  set:html={content}
/>
