---
import type { Preload } from '@/shared/types/Preload'

interface Props {
  title: string
  description: string
  preload?: Array<Preload>
  canonical?: string
  image?: string
  variant?: 'agency' | 'webs'
}

const { title, description, preload, canonical, image = '/meta-og.webp', variant = 'agency' } = Astro.props

const determineCanonicalURL = () => {
  if (Astro.url.host.includes('localhost')) return 'http://localhost:4321'
  return canonical || Astro.url.pathname
}

const canonicalURL = new URL(determineCanonicalURL(), Astro.site)
const absoluteImage = new URL(image, Astro.site)

const seoConfig = {
  agency: {
    siteName: 'Gadmin',
    ogType: 'website',
    keywords: 'agencia de software, desarrollo a medida, aplicaciones web, apps móviles, automatización, inteligencia artificial, software empresarial, desarrollo de software, Gadmin, transformación digital, consultoría tecnológica',
  },
  webs: {
    siteName: 'Gadmin Webs',
    ogType: 'website',
    keywords: 'catálogo digital, menú digital, catálogo WhatsApp, tienda online, catálogo online, pedidos WhatsApp, catálogo para negocios, menú para restaurantes, Gadmin Webs, SaaS, crear catálogo sin programar',
  },
}

const config = seoConfig[variant]
---

<title>{title}</title>
<meta charset='UTF-8' />

<meta name='description' content={description} />
<meta name='viewport' content='width=device-width' />
<link rel='icon' type='image/svg+xml' href='/favicon.svg' />

{
  preload?.map(({ href, as, type, rel = 'preload', crossorigin }) => (
    <link {rel} {href} {as} {type} {crossorigin} />
  ))
}

<link rel='canonical' href={canonicalURL} />
<meta name='theme-color' content='#0EAAF9' />

<meta name='keywords' content={config.keywords} />

<!-- Twitter meta tags -->
<meta name='twitter:card' content='summary_large_image' />
<meta name='twitter:title' content={title} />
<meta name='twitter:description' content={description} />
<meta name='twitter:image' content={absoluteImage} />

<!-- Open Graph meta tags -->
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={absoluteImage} />
<meta property='og:url' content={Astro.url.href} />
<meta property='og:site_name' content={config.siteName} />
<meta property='og:type' content={config.ogType} />
<meta property='og:locale' content='es_ES' />

<meta name='robots' content='index, follow' />
<meta name='googlebot' content='index, follow' />

<link rel='apple-touch-icon' href='/apple-touch-icon.png' />
<meta name='msapplication-config' content='/browserconfig.xml' />

<slot />
