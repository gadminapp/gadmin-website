    'name': 'Gadmin',
    'publisher': { '@id': 'https://gadmin.app/#organization' },
  },
  'about': { '@id': 'https://gadmin.app/#service' },
  'inLanguage': 'es',
}
---

<script is:inline type='application/ld+json' set:html={JSON.stringify(organizationSchema)} />
<script is:inline type='application/ld+json' set:html={JSON.stringify(professionalServiceSchema)} />
