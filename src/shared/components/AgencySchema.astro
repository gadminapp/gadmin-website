          '@type': 'Service',
          'name': 'Automatización e IA',
          'description': 'Automatización de procesos empresariales con inteligencia artificial.',
        },
      },
    ],
  },
}

/** WebPage — main landing page */
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://gadmin.app/#webpage',
  'url': 'https://gadmin.app',
  'name': 'Gadmin - Agencia de Software a Medida | Apps, Webs y Automatización',
  'description':
    'Diseñamos, desarrollamos y lanzamos software a medida que transforma tu negocio. Aplicaciones web, móviles, automatización e inteligencia artificial. Tu equipo de tecnología.',
  'isPartOf': {
    '@type': 'WebSite',
    '@id': 'https://gadmin.app/#website',
