    'url': 'https://gadmin.app/logo-bg-squared-dark.png',
    'width': 512,
    'height': 512,
  },
  'image': 'https://gadmin.app/meta-og.webp',
  'sameAs': [
    'https://www.instagram.com/gadmin.app/',
    'https://www.linkedin.com/company/gadmin-app/',
    'https://github.com/gadminapp/gadmin-website',
  ],
  'contactPoint': {
    '@type': 'ContactPoint',
    'contactType': 'sales',
    'availableLanguage': ['Spanish', 'English'],
  },
}

