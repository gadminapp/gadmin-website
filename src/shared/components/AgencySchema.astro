---
/**
 * Rich Structured Data schemas for Gadmin Agency (index page)
 * - Organization: identity, social profiles & logo
 * - ProfessionalService: Gadmin as a software development agency
 * - WebPage: main landing page markup
 *
 * Docs: https://developers.google.com/search/docs/appearance/structured-data
 */

/** Organization — brand identity */
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://gadmin.app/#organization',
  'url': 'https://gadmin.app',
  'name': 'Gadmin',
  'alternateName': 'Gadmin App',
  'description':
    'Agencia de desarrollo de software a medida. Diseñamos, desarrollamos y lanzamos aplicaciones web, móviles, automatización e inteligencia artificial para empresas.',
  'logo': {
