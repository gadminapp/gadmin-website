---
import logoBg from '@/assets/img/logo-dark.webp'
import Icon from '@/shared/components/Icon.astro'
import { Image } from 'astro:assets'

interface Props {
  isFixed?: boolean
  variant?: 'agency' | 'webs'
}

const { isFixed = true, variant = 'agency' } = Astro.props
---

<nav class:list=`nav ${isFixed ? 'nav--fixed' : ''}` transition:persist>
  <div class='wrapper nav-wrapper' data-aos='zoom-in'>
    <a href='/' class='nav-logo'>
      <Image src={logoBg} width={32} height={32} alt='Logo de Gadmin' loading='eager' />
      <p class='nav-logo-title'>
        Gadmin
        {variant === 'webs' && <span class='nav-logo-sub'>Webs</span>}
      </p>
    </a>
    <div class='nav-buttons'>
      {
        variant === 'agency' && (
          <>
            <a href='#services' class='nav-link hide-on-mobile'>
              Servicios
            </a>
            <a href='#products' class='nav-link hide-on-mobile'>
              Productos
            </a>
            <a href='#process' class='nav-link hide-on-mobile'>
              Proceso
            </a>
            <a href='#contact' class='nav-cta-btn cta--track' id='nav-contact-btn'>
              Contáctanos
            </a>
          </>
        )
      }
      {
        variant === 'webs' && (
          <>
            <a href='/webs#how-it-works' class='nav-link hide-on-mobile'>
              Cómo funciona
            </a>
            <a href='/webs#faq' class='nav-link hide-on-mobile'>
              Preguntas
            </a>
            <a href='/webs#pricing' class='nav-cta-btn cta--track' id='nav-cta-btn'>
              <span class='nav-cta-lock'>
                <Icon name='lock-closed' size={14} />
              </span>{' '}
              Preventa
            </a>
          </>
        )
      }
    </div>
  </div>
</nav>

<script>
  const contactBtn = document.getElementById('nav-contact-btn')
  const preventaBtn = document.getElementById('nav-cta-btn')

  if (contactBtn) {
    contactBtn.addEventListener('click', () => {
      // @ts-ignore
      if (typeof seline !== 'undefined') {
        // @ts-ignore
        seline.track('Agency: Contact Click')
      }
    })
  }

  if (preventaBtn) {
    preventaBtn.addEventListener('click', () => {
      // @ts-ignore
      if (typeof seline !== 'undefined') {
        // @ts-ignore
        seline.track('Webs Landing: Preventa Click')
      }
    })
  }
</script>

<style>
  .nav {
    width: 100%;
    background-color: transparent;
    transition: 0.2s ease background-color;
    z-index: 100;
  }

  .nav--fixed {
    position: fixed;
    top: 0;
    left: 0;
  }

  .nav:not(.nav--fixed),
  body.scrolled .nav {
    background-color: rgba(22, 20, 45, 0.8);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow: 0 4px 24px 0 rgba(0, 0, 0, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
  }

  .nav-buttons {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    text-decoration: none;
  }

  .nav-logo-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--white);
  }

  .nav-logo-sub {
    font-weight: 400;
    color: var(--accent);
    font-size: 0.9rem;
  }

  .nav-link {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--white);
  }

  .nav-link:visited {
    color: rgba(255, 255, 255, 0.65);
  }

  .nav-link:visited:hover {
    color: var(--white);
  }

  .nav-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 1.1rem;
    border-radius: 0.5rem;
    background: var(--primary);
    color: var(--white);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .nav-cta-btn:hover {
    background: var(--primary-lighter);
    box-shadow: 0 4px 12px rgba(77, 93, 239, 0.3);
  }

  .nav-cta-btn:visited {
    color: var(--white);
  }

  .nav-cta-lock {
    display: flex;
  }

  @media screen and (max-width: 768px) {
    .nav-wrapper {
      padding: 0.6rem 0.75rem;
    }

    .nav-cta-btn {
      font-size: 0.8rem;
      padding: 0.45rem 0.85rem;
    }
  }
</style>
