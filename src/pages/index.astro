---
import AgencyHero from '@/agency/AgencyHero.astro'
import Contact from '@/agency/Contact.astro'
// import Process from '@/agency/Process.astro'
import Products from '@/agency/Products.astro'
import Services from '@/agency/Services.astro'
import WhyUs from '@/agency/WhyUs.astro'
import AgencySchema from '@/shared/components/AgencySchema.astro'
import Footer from '@/shared/components/Footer.astro'
import Nav from '@/shared/components/Nav.astro'
import Layout from '@/shared/layouts/Layout.astro'
---

<Layout
  title='Gadmin - Ecosistema Digital para Emprendedores y PyMEs | Conty, Shop y más'
  description='Gadmin construye el mejor ecosistema digital para emprendedores y PyMEs. Conty para administrar tus ventas, Shop para tu tienda online, y aplicaciones conectadas diseñadas escuchando a nuestros clientes.'
  withSEO={true}
>
  <AgencySchema slot='schema' />
  <Nav />
  <AgencyHero />
  <Products />
  <Services />
  <WhyUs />
  <!-- <Process /> -->
  <Contact />
  <Footer />
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof seline !== 'undefined') {
      seline.track('Page view')
    }
  })

  // * Track scroll to middle of page
  let hasTrackedMiddle = false
  function trackScrollMiddle() {
    if (hasTrackedMiddle) return

    const scrollPosition = window.scrollY
    const documentHeight = document.documentElement.scrollHeight - window.innerHeight
    const scrollPercentage = (scrollPosition / documentHeight) * 100

    if (scrollPercentage >= 50) {
      hasTrackedMiddle = true
      if (typeof seline !== 'undefined') {
        seline.track('Read Page')
      }
    }
  }
  window.addEventListener('scroll', trackScrollMiddle)
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
