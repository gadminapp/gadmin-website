---
import heroMockup from '@/assets/img/hero-mockup.png'
import Icon from '@/shared/components/Icon.astro'
import { Image } from 'astro:assets'
---

<div class='hero' id='hero'>
  <div class='hero-bg'>
    <div class='hero-bg-gradient'></div>
    <div class='hero-bg-glow hero-bg-glow--1'></div>
    <div class='hero-bg-glow hero-bg-glow--2'></div>
  </div>

  <div class='hero-grid'>
    <div class='hero-content wrapper' data-aos='fade-up'>
      <div class='hero-badge' data-aos='fade-down' data-aos-delay='200'>
        <span class='hero-badge-dot'></span>
        Oferta exclusiva para los primeros negocios
      </div>

      <h1 class='hero-title'>
        Convierte tus chats de WhatsApp en <span class='text-gradient'>ventas reales</span> con un Catálogo
        Digital Profesional.
      </h1>

      <p class='hero-subtitle'>
        Olvida los PDFs lentos. Crea tu catálogo en menos de 24 horas y recibe pedidos organizados
        directamente en tu WhatsApp.
      </p>

      <div class='hero-cta-group'>
        <a href='#pricing' class='hero-cta-btn cta--track' id='hero-cta-btn'>
          Asegurar mi Precio de Preventa
          <span class='hero-cta-arrow'><Icon name='arrow-right' size={18} /></span>
        </a>
        <div class='hero-secure-badge'>
          <svg
            width='14'
            height='14'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
          >
            <rect x='3' y='11' width='18' height='11' rx='2' ry='2'></rect>
            <path d='M7 11V7a5 5 0 0 1 10 0v4'></path>
          </svg>
          Pago seguro con Stripe
        </div>
      </div>
    </div>

    <div class='hero-visual' data-aos='zoom-in' data-aos-delay='400'>
      <div class='hero-mockup-container'>
        <Image
          src={heroMockup}
          width={600}
          height={400}
          alt='Catálogo digital profesional en celular con pedido organizado en WhatsApp'
          class='hero-mockup-img'
          loading='eager'
        />
        <div class='hero-mockup-glow'></div>
      </div>
    </div>
  </div>
</div>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  @supports (height: 100svh) {
    .hero {
      min-height: 100svh;
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(160deg, #0d0b1a 0%, #16142d 40%, #1a1745 70%, #16142d 100%);
  }

  .hero-bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
  }

  .hero-bg-glow--1 {
    width: 600px;
    height: 600px;
    top: -200px;
    right: -150px;
    background: rgba(77, 93, 239, 0.15);
    animation: pulse-glow 8s ease-in-out infinite;
  }

  .hero-bg-glow--2 {
    width: 400px;
    height: 400px;
    bottom: -100px;
    left: -100px;
    background: rgba(20, 238, 244, 0.08);
    animation: pulse-glow 10s ease-in-out infinite reverse;
  }

  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }

  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 72rem;
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
    width: 100%;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 0;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    background: rgba(77, 93, 239, 0.12);
    border: 1px solid rgba(77, 93, 239, 0.25);
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .hero-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #25d366;
    animation: blink 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.12;
    color: var(--white);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    max-width: 520px;
    font-weight: 400;
  }

  .hero-cta-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .hero-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--primary) 0%, #6366f1 50%, var(--accent) 100%);
    background-size: 200% 200%;
    animation: gradient-shift 4s ease infinite;
    color: var(--white);
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      box-shadow 0.3s ease;
    box-shadow:
      0 4px 24px rgba(77, 93, 239, 0.35),
      0 0 60px rgba(20, 238, 244, 0.1);
  }

  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .hero-cta-btn:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow:
      0 8px 32px rgba(77, 93, 239, 0.45),
      0 0 80px rgba(20, 238, 244, 0.15);
  }

  .hero-cta-btn:active {
    transform: translateY(0) scale(0.99);
  }

  .hero-cta-icon {
    font-size: 1.2rem;
    display: flex;
  }

  .hero-cta-arrow {
    display: flex;
    transition: transform 0.2s ease;
  }

  .hero-cta-btn:hover .hero-cta-arrow {
    transform: translateX(4px);
  }

  .hero-secure-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.8rem;
    font-weight: 500;
    padding-left: 0.25rem;
  }

  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-mockup-container {
    position: relative;
  }

  .hero-mockup-img {
    width: 100%;
    max-width: 550px;
    height: auto;
    border-radius: 1rem;
    position: relative;
    z-index: 1;
    animation: float 6s ease-in-out infinite;
  }

  .hero-mockup-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(ellipse at center, rgba(77, 93, 239, 0.2) 0%, transparent 70%);
    border-radius: 1rem;
    z-index: 0;
    filter: blur(40px);
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @media screen and (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      padding-top: 7rem;
      gap: 2.5rem;
    }

    .hero-content {
      align-items: center;
    }

    .hero-subtitle {
      max-width: 100%;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-mockup-img {
      max-width: 420px;
    }
  }

  @media screen and (max-width: 768px) {
    .hero-grid {
      padding: 6.5rem 1rem 3rem;
      gap: 2rem;
    }

    .hero-title {
      font-size: 1.85rem;
      line-height: 1.15;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-badge {
      font-size: 0.75rem;
    }

    .hero-cta-btn {
      padding: 0.85rem 1.5rem;
      font-size: 0.95rem;
      width: 100%;
      justify-content: center;
    }

    .hero-mockup-img {
      max-width: 320px;
    }

    .hero-cta-group {
      width: 100%;
      align-items: center;
    }

    .hero-secure-badge {
      justify-content: center;
    }
  }
</style>
